<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OutWit.Database.Studio.ViewModels"
             xmlns:query="using:OutWit.Database.Studio.Views.Query"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="600"
             x:Class="OutWit.Database.Studio.Views.Query.QueryTabs"
             x:DataType="vm:QueryTabsViewModel">

    <Grid RowDefinitions="Auto,Auto,*">
        
        <!-- Tab Strip -->
        <query:QueryTabStrip Grid.Row="0"/>

        <!-- Toolbar -->
        <query:QueryToolbar Grid.Row="1"/>

        <!-- Tab Content - QueryEditor -->
        <query:QueryEditor Grid.Row="2" DataContext="{Binding SelectedTab}"/>

        <!-- Loading Overlay -->
        <query:QueryLoadingOverlay Grid.Row="2"/>
    </Grid>

</UserControl>
