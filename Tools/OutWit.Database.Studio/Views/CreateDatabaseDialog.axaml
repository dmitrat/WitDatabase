<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OutWit.Database.Studio.ViewModels"
        xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="OutWit.Database.Studio.Views.CreateDatabaseDialog"
        x:DataType="vm:ConnectionViewModel"
        Title="Create New Database"
        Width="600"
        Height="500"
        MinHeight="450"
        MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Create New Database"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Create a new WitDatabase file with custom settings"
                       Foreground="Gray"
                       FontSize="12"/>
        </StackPanel>

        <!-- Content with Tabs -->
        <TabControl Grid.Row="1">
            <!-- General Tab -->
            <TabItem Header="General">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <StackPanel Spacing="16" Margin="8">
                        <!-- Storage Type -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Storage Type:"
                                       FontWeight="SemiBold"/>
                            <ComboBox SelectedIndex="{Binding StorageType}"
                                      HorizontalAlignment="Stretch">
                                <ComboBoxItem Content="File-based database"/>
                                <ComboBoxItem Content="In-Memory database"/>
                            </ComboBox>
                        </StackPanel>

                        <!-- File Path (only for file-based) -->
                        <StackPanel Spacing="4"
                                   IsVisible="{Binding IsFileBased}">
                            <TextBlock Text="Database File:"
                                       FontWeight="SemiBold"/>
                            <Grid ColumnDefinitions="*,Auto">
                                <TextBox Grid.Column="0"
                                         Text="{Binding ConnectionInfo.FilePath, Mode=TwoWay}"
                                         Watermark="C:\Data\myapp.witdb"
                                         Margin="0,0,8,0"/>
                                <Button Grid.Column="1"
                                        Command="{Binding BrowseFileCommand}"
                                        Content="Browse..."
                                        Width="100"/>
                            </Grid>
                        </StackPanel>

                        <!-- Storage Engine -->
                        <StackPanel Spacing="4">
                            <TextBlock Text="Storage Engine:"
                                       FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding StorageEngines}"
                                      SelectedItem="{Binding SelectedStorageEngine}"
                                      HorizontalAlignment="Stretch"/>

                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,2,0,0">
                                <PathIcon Data="{x:Static ui:StudioIcons.COMMON_BULLET}" Width="10" Height="10" Foreground="Gray" />
                                <TextBlock Text="btree: Balanced read/write performance" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,0,0,0">
                                <PathIcon Data="{x:Static ui:StudioIcons.COMMON_BULLET}" Width="10" Height="10" Foreground="Gray" />
                                <TextBlock Text="lsm: Optimized for write-heavy workloads" Foreground="Gray" FontSize="11"/>
                            </StackPanel>
                        </StackPanel>

                        <!-- Encryption -->
                        <StackPanel Spacing="12">
                            <CheckBox IsChecked="{Binding ConnectionInfo.IsEncrypted}"
                                      Content="Enable database encryption (AES-GCM)"/>

                            <!-- Password -->
                            <StackPanel Spacing="4"
                                       IsVisible="{Binding ConnectionInfo.IsEncrypted}">
                                <TextBlock Text="Password:"
                                           FontWeight="SemiBold"/>
                                <TextBox Text="{Binding ConnectionInfo.Password, Mode=TwoWay}"
                                         Watermark="Enter password"
                                         PasswordChar="*"
                                         RevealPassword="False"/>

                                <StackPanel Orientation="Horizontal" Spacing="6" Margin="4,2,0,0">
                                    <PathIcon Data="{x:Static ui:StudioIcons.COMMON_WARNING}" Width="12" Height="12" Foreground="DarkOrange" />
                                    <TextBlock Text="Password cannot be recovered if lost" Foreground="DarkOrange" FontSize="11"/>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- Advanced Tab -->
            <TabItem Header="Advanced">
                <ScrollViewer HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Disabled">
                    <Grid Margin="8" ColumnDefinitions="*,*" ColumnSpacing="16" RowDefinitions="Auto,Auto,Auto">
                        <!-- Left column: page size + transactions -->
                        <StackPanel Grid.Row="0" Grid.Column="0" Spacing="4">
                            <TextBlock Text="Page Size (bytes):" FontWeight="SemiBold"/>
                            <ComboBox ItemsSource="{Binding PageSizeOptions}"
                                      SelectedItem="{Binding SelectedPageSize}"
                                      HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Default: 4096 bytes" Foreground="Gray" FontSize="11" Margin="4,2,0,0"/>
                            <TextBlock Text="Cannot be changed after creation" Foreground="DarkOrange" FontSize="11" Margin="4,0,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="0" Spacing="8" Margin="0,12,0,0">
                            <TextBlock Text="Transaction Settings:" FontWeight="SemiBold"/>
                            <CheckBox IsChecked="{Binding EnableTransactions}" Content="Enable ACID transactions"/>
                            <TextBlock Text="Provides atomicity, consistency, isolation, and durability"
                                       Foreground="Gray" FontSize="11" Margin="24,0,0,0" TextWrapping="Wrap"/>

                            <CheckBox IsChecked="{Binding EnableMvcc}"
                                      Content="Enable MVCC (Multi-Version Concurrency Control)"
                                      IsEnabled="{Binding EnableTransactions}"
                                      Margin="24,4,0,0"/>
                            <TextBlock Text="Better read performance with concurrent writes (requires more disk space)"
                                       Foreground="Gray" FontSize="11" Margin="48,0,0,0" TextWrapping="Wrap"
                                       IsVisible="{Binding EnableTransactions}"/>
                        </StackPanel>

                        <!-- Right column: cache + file locking -->
                        <StackPanel Grid.Row="0" Grid.Column="1" Spacing="4">
                            <TextBlock Text="Cache Size (pages):" FontWeight="SemiBold"/>
                            <NumericUpDown Value="{Binding CacheSize}"
                                           Minimum="10"
                                           Maximum="100000"
                                           Increment="100"
                                           FormatString="N0"
                                           HorizontalAlignment="Stretch"/>
                            <TextBlock Text="Default: 1000 pages" Foreground="Gray" FontSize="11" Margin="4,2,0,0"/>
                            <TextBlock Text="More cache = faster queries" Foreground="Gray" FontSize="11" Margin="4,0,0,0"/>
                        </StackPanel>

                        <StackPanel Grid.Row="1" Grid.Column="1" Spacing="8" Margin="0,12,0,0"
                                    IsVisible="{Binding IsFileBased}">
                            <TextBlock Text="Multi-Process Safety:" FontWeight="SemiBold"/>
                            <CheckBox IsChecked="{Binding EnableFileLocking}" Content="Enable file locking"/>
                            <TextBlock Text="Prevents corruption from concurrent access by multiple processes"
                                       Foreground="Gray" FontSize="11" Margin="24,0,0,0" TextWrapping="Wrap"/>
                        </StackPanel>
                    </Grid>
                </ScrollViewer>
            </TabItem>
        </TabControl>

        <!-- Error Message -->
        <Border Grid.Row="1"
                Background="#FFF3CD"
                BorderBrush="#FFC107"
                BorderThickness="1"
                Padding="12"
                CornerRadius="4"
                VerticalAlignment="Bottom"
                Margin="0,0,0,8"
                IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
            <StackPanel Spacing="4">
                <TextBlock Text="[!] Error"
                           FontWeight="Bold"
                           Foreground="#856404"/>
                <TextBlock Text="{Binding ErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="#856404"/>
            </StackPanel>
        </Border>

        <!-- Buttons -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              Margin="0,8,0,0">
            <StackPanel Grid.Column="0"
                       Orientation="Horizontal"
                       Spacing="8"
                       IsVisible="{Binding IsConnecting}">
                <Border Width="16" Height="16"
                        Background="{DynamicResource SystemAccentColor}"
                        CornerRadius="8">
                    <TextBlock Text="..."
                               FontSize="10"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Creating database..."
                           VerticalAlignment="Center"
                           Foreground="Gray"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="100"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="2"
                    Content="Create"
                    Command="{Binding ConnectCommand}"
                    Width="100"
                    Classes="accent"/>
        </Grid>
    </Grid>

</Window>
