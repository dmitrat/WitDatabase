<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OutWit.Database.Studio.ViewModels"
             xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="OutWit.Database.Studio.Views.TableStructure"
             x:DataType="vm:ApplicationViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <TextBlock Text="Structure"
                               FontWeight="SemiBold"
                               FontSize="14"/>

                    <StackPanel Orientation="Horizontal" Spacing="6"
                                IsVisible="{Binding TableStructureVm.SelectedObjectName, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="{Binding TableStructureVm.SelectedObjectTypeDisplay, StringFormat={}{0}:}" FontSize="12" Foreground="Gray"/>
                        <TextBlock Text="{Binding TableStructureVm.SelectedObjectName}" FontSize="12" Foreground="Gray"/>
                    </StackPanel>

                    <!-- Index details -->
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                IsVisible="{Binding TableStructureVm.IndexTableName, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <TextBlock Text="{Binding TableStructureVm.IndexTableName, StringFormat='Table: {0}'}"
                                   FontSize="11" Foreground="Gray"/>
                        <TextBlock Text="{Binding TableStructureVm.IndexIsUnique, StringFormat='Unique: {0}'}"
                                   FontSize="11" Foreground="Gray"
                                   IsVisible="{Binding TableStructureVm.IndexIsUnique, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="{Binding TableStructureVm.IndexFilterCondition, StringFormat='Filter: {0}'}"
                                   FontSize="11" Foreground="Gray"
                                   IsVisible="{Binding TableStructureVm.IndexFilterCondition, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- View definition -->
                    <TextBlock Text="{Binding TableStructureVm.ViewDefinition}"
                               FontSize="11"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               MaxHeight="60"
                               IsVisible="{Binding TableStructureVm.HasViewDefinition}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding TableStructureVm.RefreshCommand}"
                        ToolTip.Tip="Refresh"
                        Width="32"
                        Height="32"
                        Padding="0"
                        VerticalAlignment="Center">
                    <PathIcon Data="{x:Static ui:StudioIcons.TABLE_STRUCTURE_REFRESH}"
                              Width="16"
                              Height="16" />
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Empty state -->
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8"
                        IsVisible="{Binding TableStructureVm.SelectedObjectName, Converter={x:Static ObjectConverters.IsNull}}">
                <Border Width="48" Height="48"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="24"
                        HorizontalAlignment="Center">
                    <PathIcon Data="M5,4H19A2,2 0 0,1 21,6V18A2,2 0 0,1 19,20H5A2,2 0 0,1 3,18V6A2,2 0 0,1 5,4M5,8V12H11V8H5M13,8V12H19V8H13M5,14V18H11V14H5M13,14V18H19V14H13Z"
                             Width="24"
                             Height="24"
                             Foreground="Gray"/>
                </Border>
                <TextBlock Text="Select a table, view, or index to inspect"
                           FontSize="14"
                           Foreground="Gray"
                           HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Columns List -->
            <Grid IsVisible="{Binding TableStructureVm.SelectedObjectName, Converter={x:Static ObjectConverters.IsNotNull}}"
                  RowDefinitions="Auto,*">
                <!-- List header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <Grid ColumnDefinitions="*,150,80,100,150">
                        <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Type" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Nullable" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Key" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="Default" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding TableStructureVm.Columns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <Grid ColumnDefinitions="*,150,80,100,150">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataType}"
                                                   Foreground="Gray"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding IsNullable, StringFormat='Null: {0}'}"
                                                   Foreground="Gray"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="[PK]"
                                                   Foreground="Orange"
                                                   FontWeight="Bold"
                                                   IsVisible="{Binding IsPrimaryKey}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding DefaultValue, StringFormat='Default: {0}'}"
                                                   Foreground="Gray"
                                                   FontSize="12"
                                                   IsVisible="{Binding DefaultValue, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Loading overlay -->
            <Border Background="#80000000"
                    IsVisible="{Binding TableStructureVm.IsLoading}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <Border Width="32" Height="32"
                            Background="White"
                            CornerRadius="16">
                        <TextBlock Text="..."
                                   FontSize="18"
                                   Foreground="Black"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"/>
                    </Border>
                    <TextBlock Text="Loading table structure..."
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Error message -->
            <Border Background="#FFF3CD"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    Padding="8"
                    Margin="8"
                    VerticalAlignment="Top"
                    IsVisible="{Binding TableStructureVm.ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Spacing="4">
                    <TextBlock Text="[!] Error"
                               FontWeight="Bold"
                               Foreground="#856404"/>
                    <TextBlock Text="{Binding TableStructureVm.ErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="#856404"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</UserControl>
