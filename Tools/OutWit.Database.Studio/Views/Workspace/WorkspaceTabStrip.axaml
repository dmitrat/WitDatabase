<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="clr-namespace:OutWit.Database.Studio.ViewModels"
             xmlns:tabs="clr-namespace:OutWit.Database.Studio.ViewModels.Tabs"
             xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
             mc:Ignorable="d" d:DesignWidth="800" d:DesignHeight="40"
             x:Class="OutWit.Database.Studio.Views.Workspace.WorkspaceTabStrip"
             x:DataType="vm:WorkspaceTabsViewModel"
             x:Name="Root">
    
    <Border Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
            BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
            BorderThickness="0,0,0,1">
		
        <!-- Tab Headers with scroll arrows and + button -->
        <Grid ColumnDefinitions="Auto,*,Auto">
            
            <!-- Left scroll button -->
            <Button Grid.Column="0"
                    x:Name="ScrollLeftButton"
                    Width="20"
                    Height="28"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Scroll left"
                    Click="OnScrollLeftClick"
                    IsVisible="False">
                <PathIcon Data="M 10 4 L 4 10 L 10 16" 
                          Width="8" Height="8"/>
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                    </Style>
                </Button.Styles>
            </Button>
            
            <!-- Scrollable Tab Area -->
            <ScrollViewer Grid.Column="1"
                          x:Name="TabScrollViewer"
                          HorizontalScrollBarVisibility="Hidden"
                          VerticalScrollBarVisibility="Disabled">
                <StackPanel Orientation="Horizontal">
                    
                    <!-- Tab Items -->
                    <ListBox ItemsSource="{Binding Tabs}"
                             SelectedItem="{Binding SelectedTab, Mode=TwoWay}"
                             Background="Transparent"
                             BorderThickness="0">
                        
                        <ListBox.Styles>
                            <Style Selector="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0"/>
                                <Setter Property="Background" Value="Transparent"/>
                            </Style>
                            <Style Selector="ListBoxItem:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                            </Style>
                            <Style Selector="ListBoxItem:selected /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                            </Style>
                            <!-- Selected tab underline -->
                            <Style Selector="ListBoxItem:selected Border.tab-header">
                                <Setter Property="BorderThickness" Value="0,0,0,2"/>
                                <Setter Property="BorderBrush" Value="{DynamicResource SystemAccentColor}"/>
                            </Style>
                            <!-- Pinned tab styling -->
                            <Style Selector="Border.tab-header-pinned">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundBaseLowBrush}"/>
                            </Style>
                        </ListBox.Styles>
                        
                        <ListBox.ItemsPanel>
                            <ItemsPanelTemplate>
                                <StackPanel Orientation="Horizontal"/>
                            </ItemsPanelTemplate>
                        </ListBox.ItemsPanel>
                        
                        <ListBox.ItemTemplate>
                            <DataTemplate DataType="tabs:WorkspaceTabViewModel">
                                <Border Classes="tab-header"
                                        Classes.tab-header-pinned="{Binding IsPinned}"
                                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="0,0,1,0" 
                                        Padding="8,6" 
                                        Cursor="Hand"
                                        x:DataType="tabs:WorkspaceTabViewModel">

                                    <!-- Context Menu -->
                                    <Border.ContextMenu>
                                        <ContextMenu>
                                            <!-- Pin/Unpin -->
                                            <MenuItem Header="Pin Tab"
                                                      Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).PinTabCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding !IsPinned}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{x:Static ui:StudioIcons.TAB_PIN}" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Unpin Tab"
                                                      Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).UnpinTabCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsVisible="{Binding IsPinned}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{x:Static ui:StudioIcons.TAB_UNPIN}" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            
                                            <Separator/>
                                            
                                            <!-- Close options -->
                                            <MenuItem Header="Close"
                                                      Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CloseTabCommand}"
                                                      CommandParameter="{Binding}"
                                                      InputGesture="Ctrl+W"
                                                      IsEnabled="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CanCloseTab}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{x:Static ui:StudioIcons.TAB_CLOSE}" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close Others"
                                                      Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CloseOtherTabsCommand}"
                                                      CommandParameter="{Binding}"
                                                      IsEnabled="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CanCloseOtherTabs}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{x:Static ui:StudioIcons.TAB_CLOSE}" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Close All"
                                                      Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CloseAllTabsCommand}"
                                                      IsEnabled="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CanCloseAllTabs}">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{x:Static ui:StudioIcons.TAB_CLOSE}" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            
                                            <Separator/>
                                            
                                            <!-- Save (only for Query tabs) -->
                                            <MenuItem Header="Save"
                                                      Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).SaveTabCommand}"
                                                      InputGesture="Ctrl+S">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{x:Static ui:StudioIcons.QUERY_SAVE}" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                            <MenuItem Header="Save As..."
                                                      Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).SaveTabAsCommand}"
                                                      InputGesture="Ctrl+Shift+S">
                                                <MenuItem.Icon>
                                                    <PathIcon Data="{x:Static ui:StudioIcons.QUERY_SAVE}" Width="14" Height="14"/>
                                                </MenuItem.Icon>
                                            </MenuItem>
                                        </ContextMenu>
                                    </Border.ContextMenu>
                                    
                                    <StackPanel Orientation="Horizontal" Spacing="6">
                                        <!-- Tab Type Icon -->
                                        <PathIcon Data="{x:Static ui:StudioIcons.TAB_QUERY}"
                                                  Width="14" Height="14"
                                                  VerticalAlignment="Center"
                                                  Foreground="{DynamicResource SystemControlForegroundBaseMediumBrush}"/>
                                        
                                        <!-- Pin indicator -->
                                        <PathIcon Data="{x:Static ui:StudioIcons.TAB_PIN}"
                                                  Width="10" Height="10"
                                                  Foreground="{DynamicResource SystemAccentColor}"
                                                  IsVisible="{Binding IsPinned}"
                                                  VerticalAlignment="Center"/>
                                        
                                        <!-- Modified indicator -->
                                        <TextBlock Text="?"
                                                   FontSize="8"
                                                   Foreground="{DynamicResource SystemAccentColor}"
                                                   IsVisible="{Binding IsModified}"
                                                   VerticalAlignment="Center"/>
                                            
                                        <!-- Title -->
                                        <TextBlock Text="{Binding Title}"
                                                   VerticalAlignment="Center"
                                                   MaxWidth="150"
                                                   TextTrimming="CharacterEllipsis"/>
                                            
                                        <!-- Close button (hidden for pinned tabs, bound to CanCloseTab) -->
                                        <Button Width="18"
                                                Height="18"
                                                Padding="0"
                                                Background="Transparent"
                                                BorderThickness="0"
                                                Command="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CloseTabCommand}"
                                                CommandParameter="{Binding}"
                                                ToolTip.Tip="Close tab"
                                                IsVisible="{Binding !IsPinned}"
                                                IsEnabled="{Binding $parent[UserControl].((vm:WorkspaceTabsViewModel)DataContext).CanCloseTab}">
                                            <PathIcon Data="{x:Static ui:StudioIcons.TAB_CLOSE}"
                                                      Width="10" Height="10"/>
                                            <Button.Styles>
                                                <Style Selector="Button:pointerover /template/ ContentPresenter">
                                                    <Setter Property="Background" Value="#22000000"/>
                                                </Style>
                                                <Style Selector="Button:disabled PathIcon">
                                                    <Setter Property="Opacity" Value="0.3"/>
                                                </Style>
                                            </Button.Styles>
                                        </Button>
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- New Query Tab Button -->
                    <Button Width="28" 
                            Height="28" 
                            Padding="0" 
                            Margin="4,0,4,0"
                            VerticalAlignment="Center"
                            ToolTip.Tip="New Query Tab (Ctrl+N)"
                            Background="Transparent"
                            BorderThickness="0"
                            Command="{Binding NewQueryTabCommand}">
                        <PathIcon Data="{x:Static ui:StudioIcons.TAB_NEW}"
                                  Width="12" Height="12"/>
                        <Button.Styles>
                            <Style Selector="Button:pointerover /template/ ContentPresenter">
                                <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                            </Style>
                        </Button.Styles>
                    </Button>
                    
                </StackPanel>
            </ScrollViewer>
            
            <!-- Right scroll button -->
            <Button Grid.Column="2"
                    x:Name="ScrollRightButton"
                    Width="20"
                    Height="28"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0"
                    VerticalAlignment="Center"
                    ToolTip.Tip="Scroll right"
                    Click="OnScrollRightClick"
                    IsVisible="False">
                <PathIcon Data="M 6 4 L 12 10 L 6 16" 
                          Width="8" Height="8"/>
                <Button.Styles>
                    <Style Selector="Button:pointerover /template/ ContentPresenter">
                        <Setter Property="Background" Value="{DynamicResource SystemControlBackgroundListLowBrush}"/>
                    </Style>
                </Button.Styles>
            </Button>
            
        </Grid>
    </Border>
</UserControl>
