<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:tabs="clr-namespace:OutWit.Database.Studio.ViewModels.Tabs"
             xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
             mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="400"
             x:Class="OutWit.Database.Studio.Views.Workspace.StructureView"
             x:DataType="tabs:StructureTabViewModel">

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0"
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0,0,0,1"
                Padding="8">
            <Grid ColumnDefinitions="*,Auto">
                <StackPanel Grid.Column="0" VerticalAlignment="Center" Spacing="2">
                    <StackPanel Orientation="Horizontal" Spacing="8">
                        <TextBlock Text="{Binding ObjectTypeDisplay}"
                                   FontWeight="SemiBold"
                                   FontSize="14"/>
                        <TextBlock Text="{Binding ObjectName}"
                                   FontSize="14"
                                   Foreground="Gray"/>
                    </StackPanel>

                    <!-- Index details -->
                    <StackPanel Orientation="Horizontal" Spacing="12"
                                IsVisible="{Binding HasIndexDetails}">
                        <TextBlock Text="{Binding IndexTableName, StringFormat='Table: {0}'}"
                                   FontSize="11" Foreground="Gray"
                                   IsVisible="{Binding IndexTableName, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="{Binding IndexIsUnique, StringFormat='Unique: {0}'}"
                                   FontSize="11" Foreground="Gray"
                                   IsVisible="{Binding IndexIsUnique, Converter={x:Static ObjectConverters.IsNotNull}}"/>
                        <TextBlock Text="{Binding IndexFilterCondition, StringFormat='Filter: {0}'}"
                                   FontSize="11" Foreground="Gray"
                                   IsVisible="{Binding IndexFilterCondition, Converter={x:Static ObjectConverters.IsNotNull}}"
                                   TextWrapping="Wrap"/>
                    </StackPanel>

                    <!-- View definition -->
                    <TextBlock Text="{Binding ViewDefinition}"
                               FontSize="11"
                               Foreground="Gray"
                               TextWrapping="Wrap"
                               MaxHeight="60"
                               IsVisible="{Binding HasViewDefinition}"/>
                </StackPanel>

                <Button Grid.Column="1"
                        Command="{Binding RefreshCommand}"
                        IsEnabled="{Binding CanRefresh}"
                        ToolTip.Tip="Refresh"
                        Width="32"
                        Height="32"
                        Padding="0"
                        VerticalAlignment="Center">
                    <PathIcon Data="{x:Static ui:StudioIcons.TABLE_STRUCTURE_REFRESH}"
                              Width="16"
                              Height="16" />
                </Button>
            </Grid>
        </Border>

        <!-- Content -->
        <Grid Grid.Row="1">
            <!-- Columns List -->
            <Grid RowDefinitions="Auto,*">
                <!-- List header -->
                <Border Grid.Row="0"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                        BorderThickness="0,0,0,1"
                        Padding="12,6">
                    <Grid ColumnDefinitions="*,150,80,100,150">
                        <TextBlock Grid.Column="0" Text="Name" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="1" Text="Type" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="2" Text="Nullable" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="3" Text="Key" FontWeight="SemiBold"/>
                        <TextBlock Grid.Column="4" Text="Default" FontWeight="SemiBold"/>
                    </Grid>
                </Border>

                <ScrollViewer Grid.Row="1">
                    <ItemsControl ItemsSource="{Binding Columns}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                                        BorderThickness="0,0,0,1"
                                        Padding="12,8">
                                    <Grid ColumnDefinitions="*,150,80,100,150">
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Name}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding DataType}"
                                                   Foreground="Gray"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding IsNullable, StringFormat='Null: {0}'}"
                                                   Foreground="Gray"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="3"
                                                   Text="[PK]"
                                                   Foreground="Orange"
                                                   FontWeight="Bold"
                                                   IsVisible="{Binding IsPrimaryKey}"
                                                   VerticalAlignment="Center"/>

                                        <TextBlock Grid.Column="4"
                                                   Text="{Binding DefaultValue, StringFormat='Default: {0}'}"
                                                   Foreground="Gray"
                                                   FontSize="12"
                                                   IsVisible="{Binding DefaultValue, Converter={x:Static ObjectConverters.IsNotNull}}"
                                                   VerticalAlignment="Center"/>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>

            <!-- Loading overlay -->
            <Border Background="#80000000"
                    IsVisible="{Binding IsLoading}">
                <StackPanel HorizontalAlignment="Center"
                            VerticalAlignment="Center"
                            Spacing="8">
                    <Border Width="32" Height="32"
                            Background="White"
                            CornerRadius="16">
                        <PathIcon Data="{x:Static ui:StudioIcons.DB_TABLE}"
                                  Width="16" Height="16"
                                  Foreground="{DynamicResource SystemAccentColor}"/>
                    </Border>
                    <TextBlock Text="Loading structure..."
                               Foreground="White"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Error message -->
            <Border Background="#FFF3CD"
                    BorderBrush="#FFC107"
                    BorderThickness="1"
                    Padding="8"
                    Margin="8"
                    VerticalAlignment="Top"
                    IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                <StackPanel Orientation="Horizontal" Spacing="8">
                    <PathIcon Data="{x:Static ui:StudioIcons.COMMON_WARNING}"
                              Width="16" Height="16"
                              Foreground="#856404"/>
                    <TextBlock Text="{Binding ErrorMessage}"
                               TextWrapping="Wrap"
                               Foreground="#856404"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>

</UserControl>
