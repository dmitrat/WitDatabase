<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="using:OutWit.Database.Studio.ViewModels"
        mc:Ignorable="d" d:DesignWidth="600" d:DesignHeight="500"
        x:Class="OutWit.Database.Studio.Views.Dialogs.OpenDatabaseDialog"
        x:DataType="vm:ConnectionViewModel"
        Title="Open Database"
        Width="600"
        Height="500"
        MinHeight="450"
        MaxHeight="600"
        WindowStartupLocation="CenterOwner"
        CanResize="True">

    <Grid RowDefinitions="Auto,*,Auto" Margin="16">
        <!-- Header -->
        <StackPanel Grid.Row="0" Spacing="8" Margin="0,0,0,16">
            <TextBlock Text="Open Database"
                       FontSize="18"
                       FontWeight="SemiBold"/>
            <TextBlock Text="Open an existing WitDatabase file"
                       Foreground="Gray"
                       FontSize="12"/>
        </StackPanel>

        <!-- Content -->
        <TabControl Grid.Row="1">
            <TabItem Header="General">
                <StackPanel Spacing="16" Margin="8" MaxWidth="560">
                    <!-- File Path -->
                    <StackPanel Spacing="4">
                        <TextBlock Text="Database File:"
                                   FontWeight="SemiBold"/>
                        <Grid ColumnDefinitions="*,Auto">
                            <TextBox Grid.Column="0"
                                     Text="{Binding ConnectionInfo.FilePath, Mode=TwoWay}"
                                     Watermark="C:\Data\myapp.witdb"
                                     Margin="0,0,8,0"/>
                            <Button Grid.Column="1"
                                    Command="{Binding BrowseFileCommand}"
                                    Content="Browse..."
                                    Width="100"/>
                        </Grid>
                    </StackPanel>

                    <CheckBox IsChecked="{Binding UseAutoDetectedSettings}"
                              Content="Auto-detect settings from database"/>

                    <!-- Encryption -->
                    <CheckBox IsChecked="{Binding ConnectionInfo.IsEncrypted}"
                              Content="Database is encrypted"/>

                    <!-- Password -->
                    <StackPanel Spacing="4"
                                IsVisible="{Binding ConnectionInfo.IsEncrypted}">
                        <TextBlock Text="Password:"
                                   FontWeight="SemiBold"/>
                        <TextBox Text="{Binding ConnectionInfo.Password, Mode=TwoWay}"
                                 Watermark="Enter password"
                                 PasswordChar="*"
                                 RevealPassword="False"/>
                    </StackPanel>

                    <!-- Storage Engine -->
                    <StackPanel Spacing="4" IsEnabled="{Binding !UseAutoDetectedSettings}">
                        <TextBlock Text="Storage Engine:"
                                   FontWeight="SemiBold"/>
                        <ComboBox ItemsSource="{Binding StorageEngines}"
                                  SelectedItem="{Binding SelectedStorageEngine}"
                                  HorizontalAlignment="Stretch"/>
                    </StackPanel>

                    <!-- Read Only -->
                    <CheckBox IsChecked="{Binding ConnectionInfo.IsReadOnly}"
                              Content="Open in read-only mode"/>

                    <!-- Error Message -->
                    <Border Background="#FFF3CD"
                            BorderBrush="#FFC107"
                            BorderThickness="1"
                            Padding="12"
                            CornerRadius="4"
                            IsVisible="{Binding ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
                        <StackPanel Spacing="4">
                            <TextBlock Text="[!] Error"
                                       FontWeight="Bold"
                                       Foreground="#856404"/>
                            <TextBlock Text="{Binding ErrorMessage}"
                                       TextWrapping="Wrap"
                                       Foreground="#856404"/>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </TabItem>

            <TabItem Header="Advanced" IsVisible="{Binding !UseAutoDetectedSettings}">
                <Grid Margin="8" ColumnDefinitions="*,*" ColumnSpacing="16">
                    <StackPanel Grid.Column="0" Spacing="8">
                        <TextBlock Text="Transaction Settings:" FontWeight="SemiBold"/>

                        <CheckBox IsChecked="{Binding EnableTransactions}"
                                  Content="Enable ACID transactions"/>

                        <CheckBox IsChecked="{Binding EnableMvcc}"
                                  Content="Enable MVCC (Multi-Version Concurrency Control)"
                                  IsEnabled="{Binding EnableTransactions}"
                                  Margin="24,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Spacing="8">
                        <TextBlock Text="Multi-Process Safety:" FontWeight="SemiBold"/>

                        <CheckBox IsChecked="{Binding EnableFileLocking}"
                                  Content="Enable file locking"/>
                    </StackPanel>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Buttons -->
        <Grid Grid.Row="2"
              ColumnDefinitions="*,Auto,Auto"
              Margin="0,8,0,0">
            <StackPanel Grid.Column="0"
                       Orientation="Horizontal"
                       Spacing="8"
                       IsVisible="{Binding IsConnecting}">
                <Border Width="16" Height="16"
                        Background="{DynamicResource SystemAccentColor}"
                        CornerRadius="8">
                    <TextBlock Text="..."
                               FontSize="10"
                               Foreground="White"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Connecting..."
                           VerticalAlignment="Center"
                           Foreground="Gray"/>
            </StackPanel>

            <Button Grid.Column="1"
                    Content="Cancel"
                    Command="{Binding CancelCommand}"
                    Width="100"
                    Margin="0,0,8,0"/>

            <Button Grid.Column="2"
                    Content="Open"
                    Command="{Binding ConnectCommand}"
                    Width="100"
                    Classes="accent"/>
        </Grid>
    </Grid>

</Window>
