<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             xmlns:vm="using:OutWit.Database.Studio.ViewModels"
             xmlns:converters="using:OutWit.Database.Studio.Converters"
             xmlns:ui="using:OutWit.Database.Studio.Ui.Icons"
             mc:Ignorable="d" d:DesignWidth="300" d:DesignHeight="600"
             x:Class="OutWit.Database.Studio.Views.DatabaseExplorer"
             x:DataType="vm:ApplicationViewModel">

    <UserControl.Resources>
        <converters:NodeTypeToIconConverter x:Key="NodeTypeToIconConverter"/>
    </UserControl.Resources>

    <Grid RowDefinitions="Auto,*">
        <!-- Header -->
        <Border Grid.Row="0" 
                Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}" 
                BorderThickness="0,0,0,1" 
                Padding="8">
            <Grid ColumnDefinitions="*,Auto">
                <TextBlock Grid.Column="0" 
                           Text="Database Explorer" 
                           FontWeight="SemiBold" 
                           FontSize="14"
                           VerticalAlignment="Center"/>
                
                <Button Grid.Column="1"
                        Command="{Binding DatabaseExplorerVm.RefreshCommand}"
                        ToolTip.Tip="Refresh"
                        Width="32"
                        Height="32"
                        Padding="0"
                        VerticalAlignment="Center">
                    <PathIcon Data="{x:Static ui:StudioIcons.MENU_REFRESH}"
                              Width="16"
                              Height="16" />
                </Button>
            </Grid>
        </Border>

        <!-- TreeView -->
        <Border Grid.Row="1"
                BorderBrush="{DynamicResource SystemControlForegroundBaseMediumLowBrush}"
                BorderThickness="0">
            <ScrollViewer HorizontalScrollBarVisibility="Auto"
                          VerticalScrollBarVisibility="Auto">
                <TreeView ItemsSource="{Binding DatabaseExplorerVm.Nodes}"
                          SelectedItem="{Binding DatabaseExplorerVm.SelectedNode}"
                          Background="Transparent">
                    <TreeView.ItemTemplate>
                        <TreeDataTemplate ItemsSource="{Binding Children}">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <PathIcon Data="{Binding NodeType, Converter={StaticResource NodeTypeToIconConverter}}"
                                         Width="16"
                                         Height="16"/>
                                <TextBlock Text="{Binding Name}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </TreeDataTemplate>
                    </TreeView.ItemTemplate>
                    
                    <TreeView.ContextMenu>
                        <ContextMenu>
                            <!-- Create actions -->
                            <MenuItem Header="Create">
                                <MenuItem Header="Create Table..."
                                          Command="{Binding DatabaseExplorerVm.CreateTableCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="M5,4H19A2,2 0 0,1 21,6V18A2,2 0 0,1 19,20H5A2,2 0 0,1 3,18V6A2,2 0 0,1 5,4M5,8V12H11V8H5M13,8V12H19V8H13M5,14V18H11V14H5M13,14V18H19V14H13Z"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                
                                <MenuItem Header="Create View..."
                                          Command="{Binding DatabaseExplorerVm.CreateViewCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17Z"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                                
                                <MenuItem Header="Create Index..."
                                          Command="{Binding DatabaseExplorerVm.CreateIndexCommand}">
                                    <MenuItem.Icon>
                                        <PathIcon Data="M3,4H7V8H3V4M9,5V7H21V5H9M3,10H7V14H3V10M9,11V13H21V11H9M3,16H7V20H3V16M9,17V19H21V17H9"/>
                                    </MenuItem.Icon>
                                </MenuItem>
                            </MenuItem>
                            
                            <Separator/>
                            
                            <MenuItem Header="Browse Data"
                                      Command="{Binding DatabaseExplorerVm.BrowseDataCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="M5,4H19A2,2 0 0,1 21,6V18A2,2 0 0,1 19,20H5A2,2 0 0,1 3,18V6A2,2 0 0,1 5,4M5,8V12H11V8H5M13,8V12H19V8H13M5,14V18H11V14H5M13,14V18H19V14H13Z"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            
                            <MenuItem Header="View Definition"
                                      Command="{Binding DatabaseExplorerVm.ViewDefinitionCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="M12,9A3,3 0 0,0 9,12A3,3 0 0,0 12,15A3,3 0 0,0 15,12A3,3 0 0,0 12,9M12,17A5,5 0 0,1 7,12A5,5 0 0,1 12,7A5,5 0 0,1 17,12A5,5 0 0,1 12,17M12,4.5C7,4.5 2.73,7.61 1,12C2.73,16.39 7,19.5 12,19.5C17,19.5 21.27,16.39 23,12C21.27,7.61 17,4.5 12,4.5Z"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            
                            <Separator/>
                            
                            <MenuItem Header="Refresh"
                                      Command="{Binding DatabaseExplorerVm.RefreshCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="M17.65,6.35C16.2,4.9 14.21,4 12,4A8,8 0 0,0 4,12A8,8 0 0,0 12,20C15.73,20 18.84,17.45 19.73,14H17.65C16.83,16.33 14.61,18 12,18A6,6 0 0,1 6,12A6,6 0 0,1 12,6C13.66,6 15.14,6.69 16.22,7.78L13,11H20V4L17.65,6.35Z"/>
                                </MenuItem.Icon>
                            </MenuItem>
                            
                            <Separator/>
                            
                            <MenuItem Header="Drop..."
                                      Command="{Binding DatabaseExplorerVm.DropObjectCommand}">
                                <MenuItem.Icon>
                                    <PathIcon Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z" 
                                             Foreground="Red"/>
                                </MenuItem.Icon>
                            </MenuItem>
                        </ContextMenu>
                    </TreeView.ContextMenu>
                </TreeView>
            </ScrollViewer>
        </Border>

        <!-- Loading overlay -->
        <Border Grid.Row="1"
                Background="#80000000"
                IsVisible="{Binding DatabaseExplorerVm.IsLoading}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <Border Width="32" Height="32"
                        Background="White"
                        CornerRadius="16">
                    <TextBlock Text="..."
                               FontSize="18"
                               Foreground="Black"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Loading schema..."
                           Foreground="White"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- Error message -->
        <Border Grid.Row="1"
                Background="#FFF3CD"
                BorderBrush="#FFC107"
                BorderThickness="1"
                Padding="8"
                Margin="8"
                VerticalAlignment="Top"
                IsVisible="{Binding DatabaseExplorerVm.ErrorMessage, Converter={x:Static ObjectConverters.IsNotNull}}">
            <StackPanel Spacing="4">
                <TextBlock Text="[!] Error"
                           FontWeight="Bold"
                           Foreground="#856404"/>
                <TextBlock Text="{Binding DatabaseExplorerVm.ErrorMessage}"
                           TextWrapping="Wrap"
                           Foreground="#856404"/>
            </StackPanel>
        </Border>

        <!-- Empty state -->
        <Grid Grid.Row="1"
              IsVisible="{Binding !MainWindowVm.IsConnected}">
            <StackPanel HorizontalAlignment="Center"
                        VerticalAlignment="Center"
                        Spacing="8">
                <Border Width="48" Height="48"
                        Background="{DynamicResource SystemControlBackgroundChromeMediumLowBrush}"
                        CornerRadius="24"
                        HorizontalAlignment="Center">
                    <TextBlock Text="DB"
                               FontSize="18"
                               FontWeight="Bold"
                               Foreground="Gray"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Border>
                <TextBlock Text="Not Connected"
                           FontSize="14"
                           Foreground="Gray"
                           HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>

</UserControl>
