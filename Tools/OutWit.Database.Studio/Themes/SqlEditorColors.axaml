<?xml version="1.0" encoding="utf-8"?>
<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    
    <!-- 
        SQL Editor Color Resources
        Editor background/foreground colors for light theme.
        Syntax highlighting colors are defined in xshd files.
    -->
    
    <!-- Editor Background/Foreground - Light Theme -->
    <Color x:Key="SqlEditorBackgroundColor">#FFFFFF</Color>
    <Color x:Key="SqlEditorForegroundColor">#1E1E1E</Color>
    <Color x:Key="SqlEditorLineNumbersColor">#6E6E6E</Color>
    
</ResourceDictionary>