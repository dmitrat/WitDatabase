@{
    ViewData["Title"] = "About";
}

<div class="row">
    <div class="col-lg-8 mx-auto">
        <h1><i class="bi bi-info-circle me-2"></i>About</h1>
        <hr />

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-database me-2"></i>WitDatabase</h5>
            </div>
            <div class="card-body">
                <p>
                    WitDatabase is a high-performance embedded database engine for .NET applications.
                    It provides ACID-compliant transactions, SQL query support, and seamless integration
                    with Entity Framework Core.
                </p>
                <p class="mb-0">
                    <strong>Key Features:</strong>
                </p>
                <ul class="mb-0">
                    <li>ACID transactions</li>
                    <li>Entity Framework Core provider</li>
                    <li>Cross-platform support</li>
                    <li>Zero external dependencies</li>
                    <li>Encryption support</li>
                </ul>
            </div>
        </div>

        <div class="card mb-4">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-shield-lock me-2"></i>OpenIddict</h5>
            </div>
            <div class="card-body">
                <p>
                    OpenIddict is a versatile OAuth 2.0/OpenID Connect server framework for ASP.NET Core.
                    This demo shows how WitDatabase can be used as the backing store for OpenIddict.
                </p>
                <p class="mb-0">
                    <strong>Supported Flows:</strong>
                </p>
                <ul class="mb-0">
                    <li>Authorization Code Flow</li>
                    <li>Client Credentials Flow</li>
                    <li>Refresh Token Flow</li>
                </ul>
            </div>
        </div>

        <div class="card">
            <div class="card-header">
                <h5 class="mb-0"><i class="bi bi-stack me-2"></i>Technology Stack</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    <div class="col-md-6">
                        <ul class="list-unstyled mb-0">
                            <li><i class="bi bi-check text-success me-2"></i>ASP.NET Core 10</li>
                            <li><i class="bi bi-check text-success me-2"></i>Entity Framework Core 10</li>
                            <li><i class="bi bi-check text-success me-2"></i>ASP.NET Core Identity</li>
                        </ul>
                    </div>
                    <div class="col-md-6">
                        <ul class="list-unstyled mb-0">
                            <li><i class="bi bi-check text-success me-2"></i>OpenIddict 6.x</li>
                            <li><i class="bi bi-check text-success me-2"></i>WitDatabase</li>
                            <li><i class="bi bi-check text-success me-2"></i>Bootstrap 5</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>

        <div class="mt-4">
            <a href="https://github.com/dmitrat/WitDatabase" target="_blank" class="btn btn-outline-primary">
                <i class="bi bi-github me-2"></i>View on GitHub
            </a>
        </div>
    </div>
</div>
