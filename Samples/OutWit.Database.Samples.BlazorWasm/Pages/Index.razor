@page "/"
@inject DashboardViewModel ViewModel

<PageTitle>Dashboard - WitDatabase WASM</PageTitle>

<MudText Typo="Typo.h4" Class="mb-4">Dashboard</MudText>

@if (!string.IsNullOrEmpty(ViewModel.ErrorMessage))
{
    <MudAlert Severity="Severity.Error" Class="mb-4" ShowCloseIcon="true" CloseIconClicked="@(() => ViewModel.ErrorMessage = null)">
        @ViewModel.ErrorMessage
    </MudAlert>
}

@if (!ViewModel.IsDatabaseInitialized)
{
    <MudCard Class="mb-4">
        <MudCardContent>
            <MudStack AlignItems="AlignItems.Center" Spacing="4">
                @if (ViewModel.IsLoading)
                {
                    <MudProgressCircular Indeterminate="true" Color="Color.Primary" Size="Size.Large" />
                }
                else
                {
                    <MudIcon Icon="@Icons.Material.Filled.Storage" Size="Size.Large" Color="Color.Primary" />
                }
                <MudText Typo="Typo.h6">@ViewModel.StatusMessage</MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Initializing WitDatabase with IndexedDB storage...
                </MudText>
            </MudStack>
        </MudCardContent>
    </MudCard>
}
else
{
    <!-- Statistics Cards -->
    <MudGrid Class="mb-4">
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudStack AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Contacts" Size="Size.Large" Color="Color.Primary" />
                        <MudText Typo="Typo.h4">@ViewModel.ContactCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Contacts</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudStack AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Star" Size="Size.Large" Color="Color.Warning" />
                        <MudText Typo="Typo.h4">@ViewModel.FavoriteContactCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Favorite Contacts</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudStack AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.Note" Size="Size.Large" Color="Color.Info" />
                        <MudText Typo="Typo.h4">@ViewModel.NoteCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Total Notes</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
        <MudItem xs="12" sm="6" md="3">
            <MudCard>
                <MudCardContent>
                    <MudStack AlignItems="AlignItems.Center">
                        <MudIcon Icon="@Icons.Material.Filled.PushPin" Size="Size.Large" Color="Color.Success" />
                        <MudText Typo="Typo.h4">@ViewModel.PinnedNoteCount</MudText>
                        <MudText Typo="Typo.body2" Color="Color.Secondary">Pinned Notes</MudText>
                    </MudStack>
                </MudCardContent>
            </MudCard>
        </MudItem>
    </MudGrid>

    <!-- Info Card -->
    <MudCard Class="mb-4">
        <MudCardHeader>
            <CardHeaderContent>
                <MudText Typo="Typo.h6">
                    <MudIcon Icon="@Icons.Material.Filled.CheckCircle" Color="Color.Success" Class="mr-2" />
                    Database Connected
                </MudText>
            </CardHeaderContent>
        </MudCardHeader>
        <MudCardContent>
            <MudText Typo="Typo.body1" Class="mb-2">
                WitDatabase is running with <strong>IndexedDB</strong> storage in your browser.
                All data is persisted locally and survives page refreshes.
            </MudText>
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                Storage engine: <code>B+Tree</code> | Transactions: <code>Enabled</code>
            </MudText>
        </MudCardContent>
    </MudCard>

    <!-- Actions -->
    <MudPaper Elevation="0" Class="pa-4 mud-background-gray rounded">
        <MudText Typo="Typo.h6" Class="mb-3">Quick Actions</MudText>
        <MudStack Row Spacing="2" Wrap="Wrap.Wrap">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add" 
                       OnClick="@(() => ViewModel.SeedSampleDataCommand.Execute(null))"
                       Disabled="@ViewModel.IsLoading">
                Seed Sample Data
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Error" StartIcon="@Icons.Material.Filled.DeleteSweep" 
                       OnClick="@(() => ViewModel.ClearAllDataCommand.Execute(null))"
                       Disabled="@ViewModel.IsLoading">
                Clear All Data
            </MudButton>
            <MudButton Variant="Variant.Outlined" Color="Color.Default" StartIcon="@Icons.Material.Filled.Refresh" 
                       OnClick="@(() => ViewModel.LoadStatisticsCommand.Execute(null))"
                       Disabled="@ViewModel.IsLoading">
                Refresh Stats
            </MudButton>
        </MudStack>
        @if (!string.IsNullOrEmpty(ViewModel.StatusMessage) && ViewModel.StatusMessage != "Database ready!")
        {
            <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-2">
                @ViewModel.StatusMessage
            </MudText>
        }
    </MudPaper>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        ViewModel.PropertyChanged += (_, _) => InvokeAsync(StateHasChanged);
        await ViewModel.InitializeCommand.ExecuteAsync(null);
    }
}
