@page "/crud"
@using System.Text
@using OutWit.Database.Core.IndexedDb
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>CRUD Demo - WitDatabase</PageTitle>

<div class="card">
    <h1>&#128221; CRUD Operations Demo</h1>
    <p>Demonstrates basic Create, Read, Update, Delete operations using WitDatabase with IndexedDB persistence.</p>
</div>

<!-- Database Status -->
<div class="card">
    <h3>Database Status</h3>
    
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">@(_isConnected ? "&#128994;" : "&#128308;")</div>
            <div class="stat-label">@(_isConnected ? "Connected" : "Disconnected")</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@_recordCount</div>
            <div class="stat-label">Records</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@(_isPersistent ? "&#128190;" : "&#128203;")</div>
            <div class="stat-label">@(_isPersistent ? "IndexedDB" : "Memory")</div>
        </div>
    </div>
    
    @if (!_isConnected)
    {
        <div class="form-group">
            <label>
                <input type="checkbox" @bind="_usePersistentStorage" disabled="@_isInitializing" /> 
                Use IndexedDB (data persists across browser sessions)
            </label>
        </div>
        
        <button class="btn btn-primary" @onclick="InitializeDatabaseAsync" disabled="@_isInitializing">
            @if (_isInitializing)
            {
                <span>Initializing...</span>
            }
            else
            {
                <span>Initialize Database</span>
            }
        </button>
        
        <button class="btn btn-danger" style="margin-left: 10px;" @onclick="DeleteIndexedDbAsync" disabled="@_isInitializing">
            Delete IndexedDB (Clean Start)
        </button>
    }
    else
    {
        <button class="btn btn-secondary" @onclick="RefreshStatsAsync">
            Refresh Stats
        </button>
        <button class="btn btn-danger" @onclick="ClearDatabaseAsync">
            Clear All Data
        </button>
        <button class="btn btn-warning" @onclick="DisconnectAsync">
            Disconnect
        </button>
    }
</div>

@if (_isConnected)
{
    <!-- Add/Update Record -->
    <div class="card">
        <h3>Add / Update Record</h3>
        
        <div class="form-group">
            <label>Key:</label>
            <input type="text" class="form-control" @bind="_inputKey" placeholder="e.g., user:1" />
        </div>
        
        <div class="form-group">
            <label>Value (JSON):</label>
            <input type="text" class="form-control" @bind="_inputValue" placeholder='e.g., {"name":"John","age":30}' />
        </div>
        
        <button class="btn btn-success" @onclick="SaveRecordAsync" disabled="@string.IsNullOrEmpty(_inputKey)">
            Save Record
        </button>
        <button class="btn btn-primary" @onclick="LoadRecordAsync" disabled="@string.IsNullOrEmpty(_inputKey)">
            Load Record
        </button>
        <button class="btn btn-danger" @onclick="DeleteRecordAsync" disabled="@string.IsNullOrEmpty(_inputKey)">
            Delete Record
        </button>
    </div>
    
    <!-- Recent Records -->
    <div class="card">
        <h3>Stored Records</h3>
        
        @if (_records.Count == 0)
        {
            <div class="alert alert-info">
                No records stored yet. Add some records above!
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Key</th>
                        <th>Value</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in _records)
                    {
                        <tr>
                            <td><code>@record.Key</code></td>
                            <td><code>@TruncateValue(record.Value)</code></td>
                            <td>
                                <button class="btn btn-primary" style="padding: 5px 10px;" 
                                        @onclick="() => LoadRecordToForm(record.Key)">
                                    Edit
                                </button>
                                <button class="btn btn-danger" style="padding: 5px 10px;" 
                                        @onclick="() => DeleteRecordByKeyAsync(record.Key)">
                                    Delete
                                </button>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        
        <div style="margin-top: 15px;">
            <button class="btn btn-secondary" @onclick="LoadAllRecordsAsync">
                Refresh List
            </button>
        </div>
    </div>
}

<!-- Messages -->
@if (!string.IsNullOrEmpty(_message))
{
    <div class="alert @(_isError ? "alert-danger" : "alert-success")" style="white-space: pre-wrap;">
        @_message
    </div>
}

<!-- Debug Log -->
<div class="card">
    <h3>Debug Log (@_debugLog.Count entries)</h3>
    <div style="max-height: 400px; overflow-y: auto; background: #1e1e1e; color: #d4d4d4; padding: 10px; border-radius: 4px; font-family: 'Consolas', monospace; font-size: 11px;">
        @foreach (var log in _debugLog.TakeLast(100))
        {
            <div style="@(log.Contains("ERROR") || log.Contains("DEADLOCK") ? "color: #f44336;" : log.Contains("SYNC") ? "color: #ff9800;" : "")">@log</div>
        }
        @if (_debugLog.Count == 0)
        {
            <div style="color: #666;">No logs yet...</div>
        }
    </div>
    <button class="btn btn-secondary" style="margin-top: 10px;" @onclick="() => { _debugLog.Clear(); StateHasChanged(); }">
        Clear Log
    </button>
</div>

@code {
    private WitDatabase? _db;
    private bool _isConnected;
    private bool _isPersistent;
    private bool _usePersistentStorage = true;
    private int _recordCount;
    private bool _isInitializing;
    
    private string _inputKey = "";
    private string _inputValue = "";
    private string _message = "";
    private bool _isError;
    
    private List<(string Key, string Value)> _records = new();
    private List<string> _debugLog = new();
    private int _logCounter = 0;
    
    private const string DatabaseName = "WitDbCrudDemo";
    
    protected override void OnInitialized()
    {
        // Hook up IndexedDB debug logging
        StorageIndexedDb.DebugLog = Log;
    }
    
    private void Log(string message)
    {
        _logCounter++;
        var timestamp = DateTime.Now.ToString("HH:mm:ss.fff");
        _debugLog.Add($"[{timestamp}] #{_logCounter} {message}");
        
        // Keep last 500 entries
        while (_debugLog.Count > 500)
        {
            _debugLog.RemoveAt(0);
        }
        
        // Only update UI every 10 messages to avoid overwhelming
        if (_logCounter % 10 == 0)
        {
            InvokeAsync(StateHasChanged);
        }
    }
    
    private async Task DeleteIndexedDbAsync()
    {
        try
        {
            Log("=== Deleting IndexedDB database for clean start ===");
            
            // Use IndexedDbInterop to delete the database
            var interop = new IndexedDbInterop(JSRuntime, DatabaseName);
            await interop.DeleteDatabaseAsync();
            await interop.DisposeAsync();
            
            // Also delete the indexes database
            var indexInterop = new IndexedDbInterop(JSRuntime, DatabaseName + "_indexes");
            await indexInterop.DeleteDatabaseAsync();
            await indexInterop.DisposeAsync();
            
            Log("IndexedDB databases deleted successfully");
            ShowMessage("IndexedDB databases deleted. You can now initialize with a fresh database.");
        }
        catch (Exception ex)
        {
            Log($"Delete IndexedDB ERROR: {ex.Message}");
            ShowError($"Failed to delete IndexedDB: {ex.Message}");
        }
    }
    
    private async Task DisconnectAsync()
    {
        if (_db != null)
        {
            Log("Disconnecting from database...");
            await _db.DisposeAsync();
            _db = null;
        }
        
        _isConnected = false;
        _records.Clear();
        _recordCount = 0;
        Log("Disconnected");
        ShowMessage("Disconnected from database.");
        StateHasChanged();
    }
    
    private async Task InitializeDatabaseAsync()
    {
        if (_isInitializing) return;
        _isInitializing = true;
        _message = "";
        _debugLog.Clear();
        _logCounter = 0;
        
        try
        {
            Log("=== Starting database initialization ===");
            
            // Use simple builder without transactions first to test
            var builder = new WitDatabaseBuilder()
                .WithBTree();
            
            Log("Builder created with BTree (no transactions for testing)");
            
            if (_usePersistentStorage)
            {
                Log($"Configuring IndexedDB storage: {DatabaseName}");
                builder.WithIndexedDbStorage(DatabaseName, JSRuntime);
                _isPersistent = true;
            }
            else
            {
                Log("Configuring in-memory storage");
                builder.WithMemoryStorage();
                _isPersistent = false;
            }
            
            Log("Calling BuildAsync()...");
            StateHasChanged();
            await Task.Yield();
            
            _db = await builder.BuildAsync();
            
            Log("BuildAsync() completed!");
            _isConnected = true;
            
            // Load records
            Log("Loading existing records...");
            await LoadAllRecordsAsync();
            
            Log("=== Initialization complete! ===");
            ShowMessage(_isPersistent 
                ? "Database initialized with IndexedDB storage!" 
                : "Database initialized with in-memory storage.");
            
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Log($"ERROR: {ex.GetType().Name}: {ex.Message}");
            if (ex.StackTrace != null)
            {
                foreach (var line in ex.StackTrace.Split('\n').Take(10))
                {
                    Log($"  {line.Trim()}");
                }
            }
            ShowError($"Failed to initialize: {ex.GetType().Name}: {ex.Message}");
        }
        finally
        {
            _isInitializing = false;
            StateHasChanged();
        }
    }
    
    private async Task SaveRecordAsync()
    {
        if (_db == null || string.IsNullOrEmpty(_inputKey)) return;
        
        try
        {
            Log($"Saving record: {_inputKey}");
            var key = Encoding.UTF8.GetBytes(_inputKey);
            var value = Encoding.UTF8.GetBytes(_inputValue ?? "");
            
            await _db.PutAsync(key, value);
            Log("PutAsync completed");
            
            await _db.FlushAsync();
            Log("FlushAsync completed");
            
            ShowMessage($"Record '{_inputKey}' saved!");
            await LoadAllRecordsAsync();
            
            _inputKey = "";
            _inputValue = "";
        }
        catch (Exception ex)
        {
            Log($"Save ERROR: {ex.Message}");
            ShowError($"Failed to save: {ex.Message}");
        }
    }
    
    private async Task LoadRecordAsync()
    {
        if (_db == null || string.IsNullOrEmpty(_inputKey)) return;
        
        try
        {
            Log($"Loading record: {_inputKey}");
            var key = Encoding.UTF8.GetBytes(_inputKey);
            var value = await _db.GetAsync(key);
            
            if (value != null)
            {
                _inputValue = Encoding.UTF8.GetString(value);
                Log($"Record loaded, {value.Length} bytes");
                ShowMessage($"Record '{_inputKey}' loaded.");
            }
            else
            {
                Log("Record not found");
                ShowError($"Record '{_inputKey}' not found.");
            }
        }
        catch (Exception ex)
        {
            Log($"Load ERROR: {ex.Message}");
            ShowError($"Failed to load: {ex.Message}");
        }
    }
    
    private async Task DeleteRecordAsync()
    {
        if (_db == null || string.IsNullOrEmpty(_inputKey)) return;
        await DeleteRecordByKeyAsync(_inputKey);
        _inputKey = "";
        _inputValue = "";
    }
    
    private async Task DeleteRecordByKeyAsync(string key)
    {
        if (_db == null) return;
        
        try
        {
            Log($"Deleting record: {key}");
            var keyBytes = Encoding.UTF8.GetBytes(key);
            await _db.DeleteAsync(keyBytes);
            await _db.FlushAsync();
            
            Log("Delete completed");
            ShowMessage($"Record '{key}' deleted.");
            await LoadAllRecordsAsync();
        }
        catch (Exception ex)
        {
            Log($"Delete ERROR: {ex.Message}");
            ShowError($"Failed to delete: {ex.Message}");
        }
    }
    
    private void LoadRecordToForm(string key)
    {
        _inputKey = key;
        var record = _records.FirstOrDefault(r => r.Key == key);
        _inputValue = record.Value ?? "";
    }
    
    private async Task LoadAllRecordsAsync()
    {
        if (_db == null) return;
        
        try
        {
            Log("Loading all records via ScanAsync...");
            _records.Clear();
            int count = 0;
            
            await foreach (var (key, value) in _db.ScanAsync(null, null))
            {
                var keyStr = Encoding.UTF8.GetString(key);
                var valueStr = Encoding.UTF8.GetString(value);
                _records.Add((keyStr, valueStr));
                count++;
                
                if (count >= 100) 
                {
                    Log("Reached 100 records limit");
                    break;
                }
            }
            
            _recordCount = _records.Count;
            Log($"Loaded {_recordCount} records");
            StateHasChanged();
        }
        catch (Exception ex)
        {
            Log($"LoadAll ERROR: {ex.Message}");
            ShowError($"Failed to load records: {ex.Message}");
        }
    }
    
    private async Task RefreshStatsAsync()
    {
        await LoadAllRecordsAsync();
    }
    
    private async Task ClearDatabaseAsync()
    {
        if (_db == null) return;
        
        try
        {
            Log("Clearing all records...");
            var keysToDelete = _records.Select(r => Encoding.UTF8.GetBytes(r.Key)).ToList();
            foreach (var key in keysToDelete)
            {
                await _db.DeleteAsync(key);
            }
            await _db.FlushAsync();
            
            Log("All records cleared");
            ShowMessage("All records deleted.");
            await LoadAllRecordsAsync();
        }
        catch (Exception ex)
        {
            Log($"Clear ERROR: {ex.Message}");
            ShowError($"Failed to clear: {ex.Message}");
        }
    }
    
    private void ShowMessage(string message)
    {
        _message = message;
        _isError = false;
    }
    
    private void ShowError(string message)
    {
        _message = message;
        _isError = true;
    }
    
    private static string TruncateValue(string value)
    {
        return value.Length > 50 ? value[..47] + "..." : value;
    }
    
    public async ValueTask DisposeAsync()
    {
        StorageIndexedDb.DebugLog = null;
        if (_db != null)
        {
            await _db.DisposeAsync();
        }
    }
}
