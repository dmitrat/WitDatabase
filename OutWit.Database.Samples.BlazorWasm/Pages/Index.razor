<div class="card">
    <h3>Quick Start</h3>
    
    <pre style="background: #f8f9fa; padding: 15px; border-radius: 4px; overflow-x: auto;">
@@inject IJSRuntime JSRuntime
@@implements IAsyncDisposable

@@code {
    private WitDatabase? _db;
    
    protected override async Task OnInitializedAsync()
    {
        // IndexedDB storage (persistent, recommended)
        _db = await new WitDatabaseBuilder()
            .WithIndexedDbStorage("MyDatabase", JSRuntime)
            .WithBTree()
            .WithTransactions()
            .BuildAsync();  // Required for WASM
            
        // Or use in-memory storage (not persistent)
        // _db = await new WitDatabaseBuilder()
        //     .WithMemoryStorage()
        //     .BuildAsync();
    }
    
    private async Task SaveData(string key, string value)
    {
        var keyBytes = Encoding.UTF8.GetBytes(key);
        var valueBytes = Encoding.UTF8.GetBytes(value);
        
        await _db!.PutAsync(keyBytes, valueBytes);
        await _db.FlushAsync();
    }
    
    private async Task&lt;string?&gt; LoadData(string key)
    {
        var keyBytes = Encoding.UTF8.GetBytes(key);
        var value = await _db!.GetAsync(keyBytes);
        return value != null ? Encoding.UTF8.GetString(value) : null;
    }
    
    public async ValueTask DisposeAsync()
    {
        if (_db != null)
            await _db.DisposeAsync();
    }
}
    </pre>
</div>

<div class="card">
    <h3>Async API</h3>
    
    <p>All database operations support async patterns for WASM compatibility:</p>
    
    <pre style="background: #f8f9fa; padding: 15px; border-radius: 4px; overflow-x: auto;">
// Async initialization (required for WASM with IndexedDB)
var db = await builder.BuildAsync();

// Async CRUD operations
await db.PutAsync(key, value);
var value = await db.GetAsync(key);
var deleted = await db.DeleteAsync(key);

// Async iteration over all records
await foreach (var (k, v) in db.ScanAsync(null, null))
{
    Console.WriteLine($"Key: {Encoding.UTF8.GetString(k)}");
}

// Transactions with async operations
await using var tx = await db.BeginTransactionAsync();
await tx.PutAsync(key1, value1);
await tx.PutAsync(key2, value2);
await tx.CommitAsync();

// Async flush &amp; dispose
await db.FlushAsync();
await db.DisposeAsync();
    </pre>
</div>

<div class="card">
    <h3>Supported Features</h3>
    
    <ul>
        <li>? B+Tree storage engine with full async support</li>
        <li>? IndexedDB persistence (browser storage)</li>
        <li>? ACID transactions with async commit/rollback</li>
        <li>? MVCC (Multi-Version Concurrency Control)</li>
        <li>? AES-GCM encryption</li>
        <li>? Secondary indexes</li>
        <li>? Range queries with IAsyncEnumerable</li>
        <li>? LSM-Tree (requires file system, not available in browser)</li>
    </ul>
