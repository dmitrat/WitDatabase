@page "/transactions"
@using System.Text
@inject IJSRuntime JSRuntime
@implements IAsyncDisposable

<PageTitle>Transactions Demo - WitDatabase</PageTitle>

<div class="card">
    <h1>&#128188; Transactions Demo</h1>
    <p>Demonstrates transaction support with commit and rollback operations using IndexedDB storage.</p>
</div>

<!-- Database Status -->
<div class="card">
    <h3>Database Status</h3>
    
    <div class="stats-grid">
        <div class="stat-card">
            <div class="stat-value">@(_isConnected ? "&#128994;" : "&#128308;")</div>
            <div class="stat-label">@(_isConnected ? "Connected" : "Disconnected")</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">@(_activeTransaction != null ? "&#128260;" : "&#8212;")</div>
            <div class="stat-label">@(_activeTransaction != null ? "Transaction Active" : "No Transaction")</div>
        </div>
        <div class="stat-card">
            <div class="stat-value">&#128190;</div>
            <div class="stat-label">IndexedDB</div>
        </div>
    </div>
    
    @if (!_isConnected)
    {
        <button class="btn btn-primary" @onclick="InitializeDatabaseAsync">
            Initialize Database
        </button>
    }
</div>

@if (_isConnected)
{
    <!-- Transaction Controls -->
    <div class="card">
        <h3>Transaction Controls</h3>
        
        @if (_activeTransaction == null)
        {
            <button class="btn btn-primary" @onclick="BeginTransactionAsync">
                Begin Transaction
            </button>
        }
        else
        {
            <button class="btn btn-success" @onclick="CommitTransactionAsync">
                Commit
            </button>
            <button class="btn btn-danger" @onclick="RollbackTransactionAsync">
                Rollback
            </button>
        }
    </div>
    
    <!-- Add Record in Transaction -->
    <div class="card">
        <h3>Add Record @(_activeTransaction != null ? "(In Transaction)" : "")</h3>
        
        <div class="form-group">
            <label>Key:</label>
            <input type="text" class="form-control" @bind="_inputKey" placeholder="e.g., account:1" />
        </div>
        
        <div class="form-group">
            <label>Value:</label>
            <input type="text" class="form-control" @bind="_inputValue" placeholder='e.g., {"balance":1000}' />
        </div>
        
        <button class="btn btn-success" @onclick="AddRecordAsync" disabled="@string.IsNullOrEmpty(_inputKey)">
            Add Record
        </button>
    </div>
    
    <!-- Transaction Demo Scenarios -->
    <div class="card">
        <h3>Demo Scenarios</h3>
        
        <div style="margin-bottom: 15px;">
            <button class="btn btn-primary" @onclick="DemoCommitScenarioAsync">
                Demo: Add Records &amp; Commit
            </button>
            <p style="margin-top: 5px; color: #666; font-size: 12px;">
                Adds 3 records in a transaction and commits them.
            </p>
        </div>
        
        <div style="margin-bottom: 15px;">
            <button class="btn btn-primary" @onclick="DemoRollbackScenarioAsync">
                Demo: Add Records &amp; Rollback
            </button>
            <p style="margin-top: 5px; color: #666; font-size: 12px;">
                Adds 3 records in a transaction and rolls back (discards changes).
            </p>
        </div>
    </div>
    
    <!-- Current Records -->
    <div class="card">
        <h3>Current Records (Committed)</h3>
        
        @if (_committedRecords.Count == 0)
        {
            <div class="alert alert-info">
                No committed records. Run a demo scenario or add records and commit.
            </div>
        }
        else
        {
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Key</th>
                        <th>Value</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var record in _committedRecords)
                    {
                        <tr>
                            <td><code>@record.Key</code></td>
                            <td><code>@record.Value</code></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        
        <div style="margin-top: 15px;">
            <button class="btn btn-secondary" @onclick="RefreshRecordsAsync">
                Refresh
            </button>
            <button class="btn btn-danger" @onclick="ClearAllAsync">
                Clear All
            </button>
        </div>
    </div>
    
    <!-- Persistence Info -->
    <div class="card">
        <h3>&#128161; Persistence Info</h3>
        <p>
            Data is stored in browser's IndexedDB. Committed transactions persist across browser sessions!
        </p>
        <ul>
            <li>Add records and commit - they will survive page refresh.</li>
            <li>Add records and rollback - they will be discarded.</li>
            <li>Use DevTools (F12) &#8594; Application &#8594; IndexedDB to inspect stored data.</li>
        </ul>
    </div>
}

<!-- Activity Log -->
<div class="card">
    <h3>Activity Log</h3>
    
    <div style="max-height: 200px; overflow-y: auto; background: #f8f9fa; padding: 10px; border-radius: 4px; font-family: monospace; font-size: 12px;">
        @foreach (var log in _activityLog.AsEnumerable().Reverse())
        {
            <div>@log</div>
        }
        @if (_activityLog.Count == 0)
        {
            <div style="color: #666;">No activity yet...</div>
        }
    </div>
</div>

@code {
    private WitDatabase? _db;
    private ITransaction? _activeTransaction;
    private bool _isConnected;
    
    private string _inputKey = "";
    private string _inputValue = "";
    
    private List<(string Key, string Value)> _committedRecords = new();
    private List<string> _activityLog = new();
    
    private const string DatabaseName = "WitDbTransactionsDemo";
    
    private async Task InitializeDatabaseAsync()
    {
        try
        {
            // Use IndexedDB for persistent storage with BuildAsync
            _db = await new WitDatabaseBuilder()
                .WithIndexedDbStorage(DatabaseName, JSRuntime)
                .WithBTree()
                .WithTransactions()
                .BuildAsync();
            
            _isConnected = true;
            Log("Database initialized with IndexedDB storage");
            await RefreshRecordsAsync();
        }
        catch (Exception ex)
        {
            Log($"ERROR: {ex.Message}");
        }
    }
    
    private Task BeginTransactionAsync()
    {
        if (_db == null) return Task.CompletedTask;
        
        _activeTransaction = _db.BeginTransaction();
        Log("Transaction started");
        
        return Task.CompletedTask;
    }
    
    private async Task CommitTransactionAsync()
    {
        if (_activeTransaction == null) return;
        
        try
        {
            _activeTransaction.Commit();
            Log("Transaction committed - changes persisted to IndexedDB");
            
            _activeTransaction = null;
            await RefreshRecordsAsync();
        }
        catch (Exception ex)
        {
            Log($"ERROR committing: {ex.Message}");
        }
    }
    
    private async Task RollbackTransactionAsync()
    {
        if (_activeTransaction == null) return;
        
        try
        {
            _activeTransaction.Rollback();
            Log("Transaction rolled back - all changes discarded");
            
            _activeTransaction = null;
            await RefreshRecordsAsync();
        }
        catch (Exception ex)
        {
            Log($"ERROR rolling back: {ex.Message}");
        }
    }
    
    private async Task AddRecordAsync()
    {
        if (_db == null || string.IsNullOrEmpty(_inputKey)) return;
        
        try
        {
            var key = Encoding.UTF8.GetBytes(_inputKey);
            var value = Encoding.UTF8.GetBytes(_inputValue ?? "");
            
            if (_activeTransaction != null)
            {
                _activeTransaction.Put(key, value);
                Log($"Added '{_inputKey}' (in transaction - not committed yet)");
            }
            else
            {
                await _db.PutAsync(key, value);
                await _db.FlushAsync();
                Log($"Added '{_inputKey}' (auto-committed)");
                await RefreshRecordsAsync();
            }
            
            _inputKey = "";
            _inputValue = "";
        }
        catch (Exception ex)
        {
            Log($"ERROR: {ex.Message}");
        }
    }
    
    private async Task DemoCommitScenarioAsync()
    {
        if (_db == null) return;
        
        Log("--- Demo: Commit Scenario ---");
        
        await BeginTransactionAsync();
        
        var timestamp = DateTime.Now.ToString("HHmmss");
        
        _activeTransaction!.Put(
            Encoding.UTF8.GetBytes($"demo:commit:{timestamp}:1"),
            Encoding.UTF8.GetBytes($"{{\"item\":1,\"demo\":\"commit\"}}"));
        Log("Added record 1 to transaction");
        
        _activeTransaction.Put(
            Encoding.UTF8.GetBytes($"demo:commit:{timestamp}:2"),
            Encoding.UTF8.GetBytes($"{{\"item\":2,\"demo\":\"commit\"}}"));
        Log("Added record 2 to transaction");
        
        _activeTransaction.Put(
            Encoding.UTF8.GetBytes($"demo:commit:{timestamp}:3"),
            Encoding.UTF8.GetBytes($"{{\"item\":3,\"demo\":\"commit\"}}"));
        Log("Added record 3 to transaction");
        
        await CommitTransactionAsync();
        Log("--- Demo Complete: Records are now persisted in IndexedDB ---");
    }
    
    private async Task DemoRollbackScenarioAsync()
    {
        if (_db == null) return;
        
        Log("--- Demo: Rollback Scenario ---");
        
        await BeginTransactionAsync();
        
        var timestamp = DateTime.Now.ToString("HHmmss");
        
        _activeTransaction!.Put(
            Encoding.UTF8.GetBytes($"demo:rollback:{timestamp}:1"),
            Encoding.UTF8.GetBytes($"{{\"item\":1,\"demo\":\"rollback\"}}"));
        Log("Added record 1 to transaction");
        
        _activeTransaction.Put(
            Encoding.UTF8.GetBytes($"demo:rollback:{timestamp}:2"),
            Encoding.UTF8.GetBytes($"{{\"item\":2,\"demo\":\"rollback\"}}"));
        Log("Added record 2 to transaction");
        
        _activeTransaction.Put(
            Encoding.UTF8.GetBytes($"demo:rollback:{timestamp}:3"),
            Encoding.UTF8.GetBytes($"{{\"item\":3,\"demo\":\"rollback\"}}"));
        Log("Added record 3 to transaction");
        
        await RollbackTransactionAsync();
        Log("--- Demo Complete: All changes discarded ---");
    }
    
    private async Task RefreshRecordsAsync()
    {
        if (_db == null) return;
        
        _committedRecords.Clear();
        
        try
        {
            await foreach (var (key, value) in _db.ScanAsync(null, null))
            {
                var keyStr = Encoding.UTF8.GetString(key);
                var valueStr = Encoding.UTF8.GetString(value);
                _committedRecords.Add((keyStr, valueStr));
                
                if (_committedRecords.Count >= 50) break;
            }
        }
        catch (Exception ex)
        {
            Log($"ERROR refreshing: {ex.Message}");
        }
    }
    
    private async Task ClearAllAsync()
    {
        if (_db == null) return;
        
        foreach (var record in _committedRecords.ToList())
        {
            await _db.DeleteAsync(Encoding.UTF8.GetBytes(record.Key));
        }
        await _db.FlushAsync();
        
        Log("All records cleared");
        await RefreshRecordsAsync();
    }
    
    private void Log(string message)
    {
        _activityLog.Add($"[{DateTime.Now:HH:mm:ss}] {message}");
        
        // Keep last 50 entries
        if (_activityLog.Count > 50)
        {
            _activityLog.RemoveAt(0);
        }
    }
    
    public async ValueTask DisposeAsync()
    {
        _activeTransaction?.Dispose();
        if (_db != null)
        {
            await _db.DisposeAsync();
        }
    }
}
